#COLORS
theme = Rose Pine Moon
background-opacity = .4

#FONT
font-size = 16
font-family = FiraCode Nerd Font
window-title-font-family = FiraCode Nerd Font
font-style = Retina
font-style-bold = Bold
font-style-italic = Retina
font-style-bold-italic = Bold

#WINDOW
window-padding-x = 17
window-padding-y = 9
window-padding-balance = true
scrollbar = never

#MISC
mouse-hide-while-typing = true

#KEYS
keybind = shift+page_down=scroll_page_fractional:0.5
keybind = shift+page_up=scroll_page_fractional:-0.5
keybind = ctrl+enter=unbind
